{
    "name": "run_tests",
    "triggers": [
        "run tests", "execute tests", "run test suite",
        "test everything", "run all tests",
        "check tests", "verify tests", "run pytest"
    ],
    "description": "Find and execute tests, report results",
    "steps": [
        {
            "tool": "run_command",
            "description": "Finding test files",
            "params": {"command": "ls test_*.py 2>/dev/null; ls tests/ 2>/dev/null"},
            "critical": false
        },
        {
            "tool": "run_command",
            "description": "Running test suite",
            "params": {"command": "python -m pytest test_*.py -v 2>&1 || python test_*.py 2>&1 || echo 'No test runner found'"},
            "critical": true
        }
    ]
}
