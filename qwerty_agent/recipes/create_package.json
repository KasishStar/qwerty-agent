{
    "name": "create_package",
    "triggers": [
        "create package", "package structure", "make installable",
        "restructure into package", "move to package",
        "set up packaging", "create python package",
        "make a pip package"
    ],
    "description": "Restructure flat files into an installable Python package",
    "steps": [
        {
            "tool": "run_command",
            "description": "Creating package directory",
            "params": {"command": "mkdir -p pkg_name"},
            "critical": true
        },
        {
            "tool": "run_command",
            "description": "Moving Python files into package",
            "params": {"command": "cp *.py pkg_name/ 2>/dev/null; cp *.json pkg_name/ 2>/dev/null; echo 'done'"},
            "critical": true
        },
        {
            "tool": "run_command",
            "description": "Verifying package structure",
            "params": {"command": "ls pkg_name/ | head -20"},
            "critical": false
        }
    ]
}
